HF_TOKEN=your_huggingface_token_here

# Username HuggingFace Anda untuk upload/download otomatis.
# Script secara otomatis akan membuat dan merujuk ke:
#   - <username>/model      (untuk checkpoints model)
#   - <username>/tokenizer  (untuk tokenizer)
#   - <username>/dataset    (untuk dataset parquet)
# (Bisa dikosongkan jika HF_TOKEN sudah diisi, karena script akan mendeteksi username secara otomatis!)
HF_USERNAME=your_hf_username

# Konfigurasi Path Dataset (Absolute path di VM)
CPT_LOGS_DIR=/home/root/mesosfer/mesosfer/data/log
CPT_CLOUD_TELEMETRY_DIR=/home/root/mesosfer/mesosfer/data/cloud

# (Opsional) Path spesifik untuk dataset sintetik dan reverse engineering
CPT_RE_CORPUS_DIR=/home/root/mesosfer/mesosfer/data/reverse-engineering
CPT_SYNTHETIC_IR_DIR=/home/root/mesosfer/mesosfer/data/synthetic-ir
CPT_SYNTHETIC_SOC_DIR=/home/root/mesosfer/mesosfer/data/synthetic-soc

# Konfigurasi BrightData API / Proxy
BRIGHTDATA_API_KEY=your_brightdata_api_key_here
BRIGHTDATA_PROXY_URL=http://your_brightdata_proxy_url:port
